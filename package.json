{
  "name": "particular",
  "version": "0.0.0",
  "private": true,
  "description": "Adaptive arrangements for mixed-ability ensembles",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "format:check": "prettier --check .",
    "lint": "eslint 'apps/**/*.ts' 'packages/**/*.ts' --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "check:evaluation": "node -e \"console.log('Evaluation gate is introduced in U2; no corpus exists yet.')\""
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
